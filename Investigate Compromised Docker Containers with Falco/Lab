Task 1: Set up Falco for Container Security Monitoring
Step 1.1: Install Docker
# Update system packages
sudo apt update

# Install Docker dependencies
sudo apt install -y apt-transport-https ca-certificates curl gnupg lsb-release

# Add Docker GPG key
curl -fsSL https://download.docker.com/linux/ubuntu/gpg | sudo gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg

# Add Docker repository
echo "deb [arch=amd64 signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null

# Install Docker
sudo apt update
sudo apt install -y docker-ce docker-ce-cli containerd.io

# Start and enable Docker
sudo systemctl start docker
sudo systemctl enable docker

# Add user to docker group
sudo usermod -aG docker $USER
newgrp docker
Step 1.2: Install Falco
# Install Falco GPG key
curl -s https://falco.org/repo/falcosecurity-packages.asc | sudo apt-key add -

# Add Falco repository
echo "deb https://download.falco.org/packages/deb stable main" | sudo tee -a /etc/apt/sources.list.d/falcosecurity.list

# Update and install Falco
sudo apt update
sudo apt install -y falco

# Install kernel headers for Falco driver
sudo apt install -y linux-headers-$(uname -r)
Step 1.3: Configure Falco for Container Monitoring
# Create custom Falco configuration
sudo cp /etc/falco/falco.yaml /etc/falco/falco.yaml.backup

# Edit Falco configuration
sudo tee /etc/falco/falco.yaml > /dev/null << 'EOF'
rules_file:
  - /etc/falco/falco_rules.yaml
  - /etc/falco/falco_rules.local.yaml
  - /etc/falco/k8s_audit_rules.yaml
  - /etc/falco/rules.d

time_format_iso_8601: false
json_output: true
json_include_output_property: true
log_stderr: true
log_syslog: true
log_level: info
priority: debug

outputs:
  rate: 1
  max_burst: 1000

syslog_output:
  enabled: true

file_output:
  enabled: true
  keep_alive: false
  filename: /var/log/falco_events.log

stdout_output:
  enabled: true

webserver:
  enabled: true
  listen_port: 8765
  k8s_healthz_endpoint: /healthz
  ssl_enabled: false
  ssl_certificate: /etc/falco/falco.pem

grpc:
  enabled: false
  bind_address: "0.0.0.0:5060"
  threadiness: 0

grpc_output:
  enabled: false
EOF

# Create custom rules for container monitoring
sudo tee /etc/falco/rules.d/container_security.yaml > /dev/null << 'EOF'
- rule: Suspicious Container Network Activity
  desc: Detect suspicious network connections from containers
  condition: >
    spawned_process and container and
    (proc.name in (nc, ncat, netcat, wget, curl) and
     proc.args contains "-e" or proc.args contains "/bin/sh")
  output: >
    Suspicious network activity in container
    (user=%user.name command=%proc.cmdline container=%container.name
     image=%container.image.repository)
  priority: WARNING
  tags: [container, network, suspicious]

- rule: Container Privilege Escalation
  desc: Detect privilege escalation attempts in containers
  condition: >
    spawned_process and container and
    (proc.name in (sudo, su, passwd) or
     proc.args contains "chmod +s" or
     proc.args contains "setuid")
  output: >
    Privilege escalation attempt in container
    (user=%user.name command=%proc.cmdline container=%container.name
     image=%container.image.repository)
  priority: CRITICAL
  tags: [container, privilege_escalation]

- rule: Suspicious File Access in Container
  desc: Detect access to sensitive files in containers
  condition: >
    open_read and container and
    (fd.name startswith /etc/passwd or
     fd.name startswith /etc/shadow or
     fd.name startswith /root/.ssh or
     fd.name startswith /home/*/.ssh)
  output: >
    Sensitive file access in container
    (user=%user.name file=%fd.name container=%container.name
     image=%container.image.repository)
  priority: WARNING
  tags: [container, file_access, sensitive]
EOF
